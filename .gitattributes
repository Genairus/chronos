#
# https://help.github.com/articles/dealing-with-line-endings/
#

# Default: auto-detect text files and normalise to LF in the repo
* text=auto

# Source files — always LF
*.java          text eol=lf
*.g4            text eol=lf
*.kts           text eol=lf
*.gradle        text eol=lf
*.chronos       text eol=lf
*.properties    text eol=lf
*.xml           text eol=lf
*.json          text eol=lf
*.yaml          text eol=lf
*.yml           text eol=lf
*.txt           text eol=lf

# Documentation / snapshot golden files — always LF so cross-platform
# snapshot tests always read the same bytes as the generator produces
*.md            text eol=lf
*.csv           text eol=lf

# Linux start script should use lf
/gradlew        text eol=lf

# These are Windows script files and should use crlf
*.bat           text eol=crlf

# Binary files should be left untouched
*.jar           binary
*.png           binary
*.jpg           binary
*.gif           binary

